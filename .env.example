# DATABASE
DATABASE_URL=postgresql://user:password@host:port/database
DATABASE_PRIVATE_URL=postgresql://user:password@host:port/database

# AUTH & SECURITY
AUTH_SECRET=your-super-secret-key-min-32-characters-long
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=strict

# EMAIL VERIFICATION
EMAIL_PROVIDER=sendgrid # or nodemailer
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@caffeine-tracker.com
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# APP CONFIG
VITE_APP_NAME=Caffeine Clock
VITE_APP_URL=http://localhost:5173
NODE_ENV=development

# ADMIN
ADMIN_SECRET_KEY=your-admin-secret-key

# SESSION
SESSION_EXPIRY_DAYS=30
REFRESH_TOKEN_EXPIRY_DAYS=60
